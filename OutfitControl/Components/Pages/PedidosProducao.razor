@page "/PedidosProducao"
@rendermode InteractiveServer
@using OutfitControl.Database
@using OutfitControl.Database.Repositories
@using OutfitControl.Entities
@using OutfitControl.Entities.Enum
@using Microsoft.EntityFrameworkCore
@inject PedidoRepository _pedidoRepository
@inject LoteRepository _loteRepository
@inject EstoqueRepository _estoqueRepository;
@inject OutfitControlService _service

<PageTitle>Pedidos para Produção</PageTitle>

<!-- Painel lateral de estoque -->
<div style="position: fixed; top: 80px; right: 16px; z-index: 100; width: 200px; opacity: 0.92;">
    <div class="card shadow-sm border-0" style="background: #f8f9fa;">
        <div class="card-body p-2">
            <p class="fw-semibold text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase;">📦 Estoque atual</p>
            @if (!_estoque.Any())
            {
                <p class="text-muted mb-0" style="font-size: 0.75rem;">Nenhum item em estoque.</p>
            }
            else
            {
                @foreach (var item in _estoque)
                {
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span style="font-size: 0.72rem;" class="text-secondary">
                            @GetIconePeca(item.Peca.Tipo) @item.Peca.Tipo.ToString() @item.Peca.Tamanho
                        </span>
                        <span class="badge @(item.Quantidade > 0 ? "bg-success" : "bg-danger") ms-1" style="font-size: 0.68rem;">
                            @item.Quantidade
                        </span>
                    </div>
                }
            }
        </div>
    </div>
</div>

<h3 class="mb-4">Pedidos para Produção</h3>

@if (_mensagemSucesso != string.Empty)
{
    <div class="alert alert-success alert-dismissible" role="alert">
        @_mensagemSucesso
        <button type="button" class="btn-close" @onclick="() => _mensagemSucesso = string.Empty"></button>
    </div>
}

<!-- ══════════════════════════════════
     SEÇÃO 1: NOVOS PEDIDOS
     ══════════════════════════════════ -->
<div class="d-flex align-items-center mb-3 gap-2">
    <span class="badge bg-primary fs-6 px-3 py-2">Novos Pedidos</span>
    <span class="text-muted small">@_pedidosNovos.Count() pedido(s) aguardando</span>
</div>

@if (!_pedidosNovos.Any())
{
    <div class="alert alert-light border text-muted mb-4" role="alert">
        Nenhum pedido novo no momento.
    </div>
}
else
{
    <div class="row g-3 mb-5">
        @foreach (var pedido in _pedidosNovos)
        {
            bool expandido = _pedidoExpandidoId == pedido.Id;
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 @(expandido ? "border-primary border-2" : "")"
                     style="cursor: pointer; transition: box-shadow 0.2s;"
                     @onclick="() => ToggleExpandir(pedido.Id)">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@pedido.Funcionario.NomeCompleto</h5>
                                <small class="text-muted">Matrícula: <strong>@pedido.Funcionario.Matricula</strong></small>
                            </div>
                            <span class="badge bg-primary">Novo</span>
                        </div>
                        <p class="card-text text-muted small mb-0">📅 @pedido.Data.ToString("dd/MM/yyyy")</p>
                        <p class="card-text text-muted small mb-0">📦 @pedido.Pecas.Count peça(s)</p>

                        @if (expandido)
                        {
                            <hr />
                            <h6 class="fw-semibold">Peças Solicitadas:</h6>
                            <ul class="list-unstyled mb-3">
                                @foreach (var pp in pedido.Pecas)
                                {
                                    <li class="d-flex justify-content-between border-bottom py-1">
                                        <span>
                                            @GetIconePeca(pp.Peca.Tipo)
                                            <strong>@pp.Peca.Tipo.ToString()</strong> — Tam. @pp.Peca.Tamanho
                                        </span>
                                        <span class="badge bg-secondary">@pp.Quantidade</span>
                                    </li>
                                }
                            </ul>
                            <button class="btn btn-success w-100"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => EnviarParaProducao(pedido)">
                                🚀 Enviar para Produção
                            </button>
                        }
                        else
                        {
                            <p class="text-primary small mt-2 mb-0">▼ Clique para ver detalhes</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<hr class="my-4" />

<!-- ══════════════════════════════════
     SEÇÃO 2: EM PRODUÇÃO
     ══════════════════════════════════ -->
<div class="d-flex align-items-center mb-3 gap-2">
    <span class="badge bg-warning text-dark fs-6 px-3 py-2">Em Produção</span>
    <span class="text-muted small">@_pedidosEmProcesso.Count() pedido(s) em andamento</span>
</div>

@if (!_pedidosEmProcesso.Any())
{
    <div class="alert alert-light border text-muted mb-4" role="alert">
        Nenhum pedido em produção no momento.
    </div>
}
else
{
    <div class="row g-3 mb-5">
        @foreach (var pedido in _pedidosEmProcesso)
        {
            bool expandido = _pedidoExpandidoId == pedido.Id;
            bool podeRetirar = PedidoPodeSerRetirado(pedido);

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 border-warning @(expandido ? "border-2" : "")"
                     style="cursor: pointer; transition: box-shadow 0.2s;"
                     @onclick="() => ToggleExpandir(pedido.Id)">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@pedido.Funcionario.NomeCompleto</h5>
                                <small class="text-muted">Matrícula: <strong>@pedido.Funcionario.Matricula</strong></small>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1">
                                <span class="badge bg-warning text-dark">Em Produção</span>
                                @if (podeRetirar)
                                {
                                    <span class="badge bg-success" style="font-size: 0.65rem;">✅ Estoque OK</span>
                                }
                            </div>
                        </div>
                        <p class="card-text text-muted small mb-0">📅 @pedido.Data.ToString("dd/MM/yyyy")</p>
                        <p class="card-text text-muted small mb-0">📦 @pedido.Pecas.Count peça(s)</p>

                        @if (expandido)
                        {
                            <hr />
                            <h6 class="fw-semibold">Peças Solicitadas:</h6>
                            <ul class="list-unstyled mb-2">
                                @foreach (var pp in pedido.Pecas)
                                {
                                    int qtdEstoque = ObterEstoquePeca(pp.Peca);
                                    bool itemOk = qtdEstoque >= pp.Quantidade;
                                    <li class="d-flex justify-content-between border-bottom py-1">
                                        <span>
                                            @GetIconePeca(pp.Peca.Tipo)
                                            <strong>@pp.Peca.Tipo.ToString()</strong> — Tam. @pp.Peca.Tamanho
                                        </span>
                                        <div class="d-flex align-items-center gap-1">
                                            <span class="badge bg-secondary">@pp.Quantidade</span>
                                            <span class="badge @(itemOk ? "bg-success" : "bg-danger")" style="font-size: 0.65rem;">
                                                @(itemOk ? "✓" : $"falta {pp.Quantidade - qtdEstoque}")
                                            </span>
                                        </div>
                                    </li>
                                }
                            </ul>

                            @if (podeRetirar)
                            {
                                <button class="btn btn-success w-100 mt-2"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => EnviarParaRetirada(pedido)">
                                    🎽 Enviar para Retirada
                                </button>
                            }
                            else
                            {
                                <div class="alert alert-warning py-1 px-2 mt-2 mb-0 small">
                                    ⚠️ Estoque insuficiente para liberar retirada.
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-warning small mt-2 mb-0">▼ Clique para ver detalhes</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<hr class="my-4" />

<!-- ══════════════════════════════════
     SEÇÃO 3: RETIRADA
     ══════════════════════════════════ -->
<div class="d-flex align-items-center mb-3 gap-2">
    <span class="badge bg-success fs-6 px-3 py-2">Retirada</span>
    <span class="text-muted small">@_pedidosAguardandoRetirada.Count() pedido(s) prontos para entregar</span>
</div>

@if (!_pedidosAguardandoRetirada.Any())
{
    <div class="alert alert-light border text-muted" role="alert">
        Nenhum pedido aguardando retirada no momento.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var pedido in _pedidosAguardandoRetirada)
        {
            bool expandido = _pedidoExpandidoId == pedido.Id;
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 border-success @(expandido ? "border-2" : "")"
                     style="cursor: pointer; transition: box-shadow 0.2s;"
                     @onclick="() => ToggleExpandir(pedido.Id)">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@pedido.Funcionario.NomeCompleto</h5>
                                <small class="text-muted">Matrícula: <strong>@pedido.Funcionario.Matricula</strong></small>
                            </div>
                            <span class="badge bg-success">Pronto p/ Retirar</span>
                        </div>
                        <p class="card-text text-muted small mb-0">📅 @pedido.Data.ToString("dd/MM/yyyy")</p>
                        <p class="card-text text-muted small mb-0">📦 @pedido.Pecas.Count peça(s)</p>

                        @if (expandido)
                        {
                            <hr />
                            <h6 class="fw-semibold">Peças a Entregar:</h6>
                            <ul class="list-unstyled mb-3">
                                @foreach (var pp in pedido.Pecas)
                                {
                                    <li class="d-flex justify-content-between border-bottom py-1">
                                        <span>
                                            @GetIconePeca(pp.Peca.Tipo)
                                            <strong>@pp.Peca.Tipo.ToString()</strong> — Tam. @pp.Peca.Tamanho
                                        </span>
                                        <span class="badge bg-secondary">@pp.Quantidade</span>
                                    </li>
                                }
                            </ul>
                            <button class="btn btn-success w-100"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => FinalizarRetirada(pedido)">
                                ✅ Finalizar — Uniforme Entregue
                            </button>
                        }
                        else
                        {
                            <p class="text-success small mt-2 mb-0">▼ Clique para confirmar entrega</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private IEnumerable<Pedido> _pedidosNovos = [];
    private IEnumerable<Pedido> _pedidosEmProcesso = [];
    private IEnumerable<Pedido> _pedidosAguardandoRetirada = [];
    private int? _pedidoExpandidoId = null;
    private string _mensagemSucesso = string.Empty;

    private IEnumerable<Estoque> _estoque = new List<Estoque>();

    protected override void OnInitialized()
    {
        CarregarPedidos();
        CarregarEstoque();
    }

    private void CarregarPedidos()
    {
        var todos = _pedidoRepository.GetAllComDetalhes().ToList();
        _pedidosNovos              = todos.Where(p => p.Status == StatusPedido.Novo).ToList();
        _pedidosEmProcesso         = todos.Where(p => p.Status == StatusPedido.EmProcesso).ToList();
        _pedidosAguardandoRetirada = todos.Where(p => p.Status == StatusPedido.AguardandoRetirada).ToList();
    }

    private void CarregarEstoque()
    {
        _estoque = _estoqueRepository.GetAll().Where(e => e.Quantidade > 0).ToList();
    }

    private int ObterEstoquePeca(Peca peca)
    {
        return _estoque.FirstOrDefault(e => e.Id == peca.Id)?.Quantidade ?? 0;
    }

    private bool PedidoPodeSerRetirado(Pedido pedido)
    {
        return pedido.Pecas.All(pp => ObterEstoquePeca(pp.Peca) >= pp.Quantidade);
    }

    private void ToggleExpandir(int pedidoId)
    {
        _pedidoExpandidoId = _pedidoExpandidoId == pedidoId ? null : pedidoId;
    }

    private void EnviarParaProducao(Pedido pedido)
    {
        _service.SolicitarFabricacaoUniforme(new List<Pedido> { pedido });
        _pedidoExpandidoId = null;
        _mensagemSucesso = $"Pedido de {pedido.Funcionario.NomeCompleto} enviado para produção com sucesso!";
        CarregarPedidos();
        CarregarEstoque();
    }

    private void EnviarParaRetirada(Pedido pedido)
    {
        _service.AprovarRetirada(pedido);
        _pedidoExpandidoId = null;
        _mensagemSucesso = $"Pedido de {pedido.Funcionario.NomeCompleto} liberado para retirada. Estoque descontado.";
        CarregarPedidos();
        CarregarEstoque();
    }

    private void FinalizarRetirada(Pedido pedido)
    {
        _service.FinalizarRetirada(pedido);
        _pedidoExpandidoId = null;
        _mensagemSucesso = $"Uniforme de {pedido.Funcionario.NomeCompleto} entregue e pedido finalizado!";
        CarregarPedidos();
        CarregarEstoque();
    }

    private string GetIconePeca(TipoPeca tipo) => tipo switch
    {
        TipoPeca.Camiseta => "👕",
        TipoPeca.Calca    => "👖",
        TipoPeca.Calcado  => "👟",
        _                 => "📦"
    };
}
